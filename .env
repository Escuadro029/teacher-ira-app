# ─── EMAIL DELIVERY ──────────────────────────
# Option A: Gmail (use an App Password, NOT your real password)
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Generate a password for "Mail"
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Option B: SendGrid (more reliable for production)
#   Replace the nodemailer transport in server.js with:
#   service: 'SendGrid', auth: { user: 'apikey', pass: SENDGRID_API_KEY }
# SENDGRID_API_KEY=SG.your_key_here

# ─── EMAIL CONTENT ───────────────────────────
